# BuhlOS — environment variables
#
# Copy to .env.local and fill in real values. .env.local is gitignored.

# ── Required (production) ─────────────────────────────────────────────

# HMAC key for the buhl_session cookie. Must be ≥ 16 chars in prod.
SESSION_SECRET=

# Vercel Blob read/write token (Vercel dashboard → Storage → Blob).
BLOB_READ_WRITE_TOKEN=

# ── Canonical domain configuration ────────────────────────────────────
#
# Defaults match the production plan and are baked into the central
# config (api/_lib/domains.js + public/lib/domains.js). Override these
# in preview/staging/local dev to point at non-prod URLs without code
# changes.

NEXT_PUBLIC_BUHLOS_URL=https://buhlos.com
NEXT_PUBLIC_PHIL_URL=https://phil.buhlos.com
NEXT_PUBLIC_API_URL=https://api.buhlos.com

# Optional future docs/help surface.
# NEXT_PUBLIC_DOCS_URL=https://docs.buhlos.com

# Optional — set once admin and Phil are split across subdomains so the
# session cookie is honoured at both buhlos.com and phil.buhlos.com.
# Leave unset in dev: localhost cookies must stay host-only.
# BUHLOS_COOKIE_DOMAIN=.buhlos.com

# Comma-separated extra origins allowed to make credentialed calls to
# the API (joins the built-in allow-list of buhlos.com / phil.buhlos.com
# / api.buhlos.com / localhost). Use for preview deployments.
# ALLOWED_ORIGINS=https://staging.buhlos.com,https://preview-xyz.vercel.app

# ── Email transport (Resend) ──────────────────────────────────────────

# Resend API key for transactional emails (snag emails, access requests,
# password reset alerts). When unset, those flows log + skip silently.
RESEND_API_KEY=

# Inbox for admin alerts (access requests, password resets).
# ADMIN_ALERT_EMAIL=office@buhlos.com

# From-address for system emails. Must be a domain you've verified in
# Resend (with DKIM/SPF). Default is noreply@buhlos.com.
# NOREPLY_EMAIL=noreply@buhlos.com

# Override for the snag-email From: header specifically. Defaults to
# "BUHL Snags <noreply@buhlos.com>".
# SNAG_EMAIL_FROM=BUHL Snags <noreply@buhlos.com>

# ── Push notifications (web-push / VAPID) ─────────────────────────────

# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:office@buhlos.com

# ── Cache controls ────────────────────────────────────────────────────

# Disable the in-memory blob read cache (set to 1 for cron jobs that
# need strictly fresh reads). Default: cache enabled.
# BLOB_CACHE_DISABLE=0
