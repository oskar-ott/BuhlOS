{
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    { "source": "/jobs/:jobId", "destination": "/index.html" },

    { "source": "/admin",                 "destination": "/admin/index.html" },
    { "source": "/admin/",                "destination": "/admin/index.html" },
    { "source": "/admin/operations",      "destination": "/admin/operations.html" },
    { "source": "/admin/approvals",       "destination": "/admin/approvals.html" },
    { "source": "/admin/snags",           "destination": "/admin/snags.html" },
    { "source": "/admin/jobs",            "destination": "/admin/jobs.html" },
    { "source": "/admin/jobs/:jobId",     "destination": "/admin/job.html" },
    { "source": "/admin/quotes",          "destination": "/admin/quotes.html" },
    { "source": "/admin/quotes/:quoteId", "destination": "/admin/quote.html" },
    { "source": "/admin/hours",           "destination": "/admin/hours.html" },
    { "source": "/admin/crew",            "destination": "/admin/crew.html" },
    { "source": "/admin/suppliers",       "destination": "/admin/suppliers.html" },
    { "source": "/admin/temps",           "destination": "/admin/temps.html" },
    { "source": "/admin/settings",        "destination": "/admin/settings.html" },
    { "source": "/admin/support",         "destination": "/admin/support.html" },
    { "source": "/admin/assets",          "destination": "/admin/assets.html" },
    { "source": "/admin/activity",        "destination": "/admin/activity.html" },
    { "source": "/admin/materials",       "destination": "/admin/materials.html" },

    { "source": "/dev/site-office",            "destination": "/dev/site-office/components.html" },
    { "source": "/dev/site-office/components", "destination": "/dev/site-office/components.html" },

    { "source": "/admin-legacy", "destination": "/admin.html" },

    { "source": "/overview",  "destination": "/admin/operations.html" },
    { "source": "/my-day",    "destination": "/my-day.html" },
    { "source": "/my-gear",   "destination": "/my-gear.html" },
    { "source": "/install",   "destination": "/install.html" },
    { "source": "/approvals", "destination": "/admin/approvals.html" },
    { "source": "/client", "destination": "/client.html" },
    { "source": "/", "destination": "/login.html" }
  ],
  "crons": [
    { "path": "/api/notifications?action=send-daily-reminders", "schedule": "30 5 * * 1-5" },
    { "path": "/api/notifications?action=send-tag-reminders",   "schedule": "0 22 * * 0"   }
  ]
}
